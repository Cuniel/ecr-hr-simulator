{
  "name": "ecr-hr-simulator",
  "version": "2.0.0",
  "description": "自动操作系统 - Web版",
  "main": "main.js",
  "scripts": {
    "start": "node server.js",
    "dev": "NODE_ENV=development node server.js",
    "cli": "node main.js",
    "clockin": "node main.js",
    "clockin-headless": "node main.js --headless",
    "clockin-test": "node main.js --test",
    "test-headless": "node main.js --headless --test",
    "docker:build": "docker build -f docker/Dockerfile -t ecr-hr-simulator .",
    "docker:run": "docker compose -f docker/docker-compose.yml up -d",
    "docker:dev": "docker compose -f docker/docker-compose.yml up --build",
    "docker:stop": "docker compose -f docker/docker-compose.yml down",
    "docker:logs": "docker compose -f docker/docker-compose.yml logs -f",
    "docker:shell": "docker compose -f docker/docker-compose.yml exec ecr-hr-simulator sh",
    "docker:build-multi": "docker buildx build --platform linux/amd64,linux/arm64 -f docker/Dockerfile -t ecr-hr-simulator .",
    "docker:clean": "docker system prune -f && docker image prune -f"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "playwright": "^1.40.0",
    "rate-limiter-flexible": "^11.2.0"
  },
  "keywords": [
    "automation",
    "attendance",
    "clockin",
    "web",
    "aws"
  ]
}
