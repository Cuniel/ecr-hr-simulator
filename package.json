{
  "name": "daka-simulator",
  "version": "2.0.0",
  "description": "自动打卡系统 - Web版",
  "main": "main.js",
  "scripts": {
    "start": "node server.js",
    "dev": "NODE_ENV=development node server.js",
    "cli": "node main.js",
    "clockin": "node main.js",
    "clockin-headless": "node main.js --headless",
    "clockin-dry": "node main.js --dry-run",
    "test-headless": "node main.js --headless --dry-run",
    
    "docker:build": "docker build -t daka-simulator .",
    "docker:run": "docker-compose up -d",
    "docker:dev": "docker-compose -f docker-compose.dev.yml up -d",
    "docker:stop": "docker-compose down",
    "docker:logs": "docker-compose logs -f",
    "docker:shell": "docker-compose exec daka-simulator sh",
    
    "docker:build-multi": "docker buildx build --platform linux/amd64,linux/arm64 -t daka-simulator .",
    "docker:clean": "docker system prune -f && docker image prune -f"
  },
  "dependencies": {
    "playwright": "^1.40.0",
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "helmet": "^7.1.0",
    "rate-limiter-flexible": "^3.0.8",
    "bcryptjs": "^2.4.3",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1"
  },
  "keywords": ["automation", "attendance", "clockin", "web", "aws"]
}